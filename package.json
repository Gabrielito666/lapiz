{
	"name": "lapiz",
	"version": "2.0.8-beta",
	"description": "jsDocs typed APIS maker",
	"license": "ISC",
	"author": "Gabriel Farías R",
	"type": "commonjs",
	"main": "./lib/apiz/index.js",
	"keywords": [
		"api",
		"express",
		"validation",
		"type-safe",
		"rest",
		"sdk",
		"backend",
		"frontend"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Gabrielito666/lapiz"
	},
	"files": [
		"lib/",
		"LICENSE",
		"README.md",
		"jsconfig.js"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"imports": {
		"#lib/*": "./lib/*",
		"#module-js-lib/*": "./module-js-lib/*",
		"#test/*": "./tests/*"
	},
	"exports": {
        	"./sdk": {
			"import": "./module-js.lib/sdk/index.js",
			"require": "./lib/sdk/index.js"
		},
        	"./api-caller": {
			"import": "./module-js-lib/api-caller/index.js",
			"require": "./lib/api-caller/index.js"
		},
        	"./router": {
			"import": "./module-js-lib/router/index.js",
			"require": "./lib/router/index.js"
		},
        	"./route-handler": {
			"import": "./module-js-lib/route-handler/index.js",
			"require": "./lib/route-handler/index.js"
		},
		"./frontend-error": {
			"import": "./module-js-lib/frontend-error/index.js",
			"require": "./lib/frontend-error/index.js"
		},
        	"./backend-error": {
			"import": "./module-js-lib/backend-error/index.js",
			"require": "./lib/backend-error/index.js"
		}
  	},
	"scripts": {
		"to-esm": "node scripts/to-esm.js",
		"test": "node --test"
	},
	"dependencies": {
		"express": "5.1.0"
	},
	"devDependencies": {
		"@types/express": "5.0.6"
	}
}
