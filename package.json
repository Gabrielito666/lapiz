{
	"name": "lapiz",
	"version": "2.0.1-beta",
	"description": "jsDocs typed APIS maker",
	"license": "ISC",
	"author": "Gabriel Farías R",
	"type": "commonjs",
	"main": "./lib/lapiz/index.js",
	"keywords": [
		"api",
		"express",
		"validation",
		"type-safe",
		"rest",
		"sdk",
		"backend",
		"frontend"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Gabrielito666/lapiz"
	},
	"files": [
		"lib/",
		"LICENSE",
		"README.md",
		"jsconfig.js"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"imports": {
		"#lib/*": "./lib/*"
	},
	"exports": {
        	"./sdk": { "import": "./lib/sdk/index.js" },
        	"./api-caller": { "import": "./lib/api-caller/index.js" },
        	"./router": { "require": "./lib/router/index.js" },
        	"./route-handler": { "require": "./lib/route-handler/index.js" },
		"./frontend-error": { "import": "./lib/frontend-error/index.js" },
        	"./backend-error": { "require": "./lib/backend-error/index.js" }
  	},
	"dependencies": {
		"express": "5.1.0"
	},
	"devDependencies": {
		"@types/express": "5.0.6"
	}
}
